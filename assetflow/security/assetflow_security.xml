<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================ -->
    <!--  Module category                                                  -->
    <!-- ================================================================ -->
    <record id="module_category_assetflow" model="ir.module.category">
        <field name="name">AssetFlow</field>
        <field name="description">Asset &amp; Resource Management roles.</field>
        <field name="sequence">20</field>
    </record>

    <!-- ================================================================ -->
    <!--  Groups                                                           -->
    <!--                                                                   -->
    <!--  The four roles form a strict privilege chain through implied_ids:-->
    <!--      Employee ⊂ Department Head ⊂ Asset Manager ⊂ Administrator   -->
    <!--  so granting a role automatically grants every role beneath it.   -->
    <!-- ================================================================ -->
    <record id="group_assetflow_employee" model="res.groups">
        <field name="name">Employee</field>
        <field name="category_id" ref="module_category_assetflow"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="comment">View own allocations, book shared resources and raise maintenance requests.</field>
    </record>

    <record id="group_assetflow_dept_head" model="res.groups">
        <field name="name">Department Head</field>
        <field name="category_id" ref="module_category_assetflow"/>
        <field name="implied_ids" eval="[(4, ref('group_assetflow_employee'))]"/>
        <field name="comment">See every allocation of the department they run and approve its transfers.</field>
    </record>

    <record id="group_assetflow_manager" model="res.groups">
        <field name="name">Asset Manager</field>
        <field name="category_id" ref="module_category_assetflow"/>
        <field name="implied_ids" eval="[(4, ref('group_assetflow_dept_head'))]"/>
        <field name="comment">Register and allocate assets, approve maintenance, run and resolve audits.</field>
    </record>

    <record id="group_assetflow_admin" model="res.groups">
        <field name="name">Administrator</field>
        <field name="category_id" ref="module_category_assetflow"/>
        <field name="implied_ids" eval="[(4, ref('group_assetflow_manager'))]"/>
        <field name="comment">Full system setup: departments, categories and user roles.</field>
    </record>

    <!-- Every internal user is an AssetFlow Employee out of the box: this is
         what makes "signup defaults to Employee" true without any custom hook.
         Elevation above Employee is guarded in res.users._check_role_grant. -->
    <record id="base.group_user" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('assetflow.group_assetflow_employee'))]"/>
    </record>

    <!-- Bootstrap: the installing administrator becomes an AssetFlow admin,
         otherwise nobody could ever hand out the first role. -->
    <record id="base.user_admin" model="res.users">
        <field name="groups_id" eval="[(4, ref('assetflow.group_assetflow_admin'))]"/>
    </record>

    <!-- ================================================================ -->
    <!--  Record rules                                                     -->
    <!--                                                                   -->
    <!--  Rules of the different groups a user belongs to are OR-ed, so a  -->
    <!--  manager's "see everything" rule always wins over the narrower    -->
    <!--  employee rule it inherits.                                       -->
    <!-- ================================================================ -->

    <!-- ==== Multi-company (global, AND-ed with everything else) -->
    <record id="rule_asset_company" model="ir.rule">
        <field name="name">Asset: multi-company</field>
        <field name="model_id" ref="model_assetflow_asset"/>
        <field name="global" eval="True"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
    </record>

    <record id="rule_department_company" model="ir.rule">
        <field name="name">Department: multi-company</field>
        <field name="model_id" ref="model_assetflow_department"/>
        <field name="global" eval="True"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
    </record>

    <record id="rule_category_company" model="ir.rule">
        <field name="name">Asset Category: multi-company</field>
        <field name="model_id" ref="model_assetflow_asset_category"/>
        <field name="global" eval="True"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
    </record>

    <!-- ==== Allocations -->
    <record id="rule_allocation_employee" model="ir.rule">
        <field name="name">Allocation: own records only</field>
        <field name="model_id" ref="model_assetflow_asset_allocation"/>
        <field name="groups" eval="[(4, ref('group_assetflow_employee'))]"/>
        <field name="domain_force">['|', ('employee_id', '=', user.id), ('create_uid', '=', user.id)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <record id="rule_allocation_dept_head" model="ir.rule">
        <field name="name">Allocation: whole department</field>
        <field name="model_id" ref="model_assetflow_asset_allocation"/>
        <field name="groups" eval="[(4, ref('group_assetflow_dept_head'))]"/>
        <field name="domain_force">['|', '|',
            ('employee_id', '=', user.id),
            ('department_id.manager_id', '=', user.id),
            ('department_id', '=', user.department_id.id)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <record id="rule_allocation_manager" model="ir.rule">
        <field name="name">Allocation: all records</field>
        <field name="model_id" ref="model_assetflow_asset_allocation"/>
        <field name="groups" eval="[(4, ref('group_assetflow_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

    <!-- ==== Resource bookings -->
    <record id="rule_booking_employee" model="ir.rule">
        <field name="name">Booking: own bookings</field>
        <field name="model_id" ref="model_assetflow_resource_booking"/>
        <field name="groups" eval="[(4, ref('group_assetflow_employee'))]"/>
        <field name="domain_force">['|', ('user_id', '=', user.id), ('create_uid', '=', user.id)]</field>
        <field name="perm_read" eval="False"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- Everyone may *read* every booking: a shared calendar with invisible
         slots would be useless. Writing stays restricted by the rule above. -->
    <record id="rule_booking_read_all" model="ir.rule">
        <field name="name">Booking: calendar is public</field>
        <field name="model_id" ref="model_assetflow_resource_booking"/>
        <field name="groups" eval="[(4, ref('group_assetflow_employee'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_booking_manager" model="ir.rule">
        <field name="name">Booking: manage all</field>
        <field name="model_id" ref="model_assetflow_resource_booking"/>
        <field name="groups" eval="[(4, ref('group_assetflow_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

    <!-- ==== Maintenance -->
    <record id="rule_maintenance_employee" model="ir.rule">
        <field name="name">Maintenance: own requests</field>
        <field name="model_id" ref="model_assetflow_maintenance"/>
        <field name="groups" eval="[(4, ref('group_assetflow_employee'))]"/>
        <field name="domain_force">['|', '|',
            ('requester_id', '=', user.id),
            ('create_uid', '=', user.id),
            ('technician_id', '=', user.id)]</field>
    </record>

    <record id="rule_maintenance_dept_head" model="ir.rule">
        <field name="name">Maintenance: department requests</field>
        <field name="model_id" ref="model_assetflow_maintenance"/>
        <field name="groups" eval="[(4, ref('group_assetflow_dept_head'))]"/>
        <field name="domain_force">['|', '|',
            ('requester_id', '=', user.id),
            ('department_id.manager_id', '=', user.id),
            ('department_id', '=', user.department_id.id)]</field>
    </record>

    <record id="rule_maintenance_manager" model="ir.rule">
        <field name="name">Maintenance: all requests</field>
        <field name="model_id" ref="model_assetflow_maintenance"/>
        <field name="groups" eval="[(4, ref('group_assetflow_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

    <record id="rule_maintenance_log_employee" model="ir.rule">
        <field name="name">Maintenance log: own work</field>
        <field name="model_id" ref="model_assetflow_maintenance_log"/>
        <field name="groups" eval="[(4, ref('group_assetflow_employee'))]"/>
        <field name="domain_force">['|',
            ('technician_id', '=', user.id),
            ('maintenance_id.requester_id', '=', user.id)]</field>
    </record>

    <record id="rule_maintenance_log_manager" model="ir.rule">
        <field name="name">Maintenance log: all</field>
        <field name="model_id" ref="model_assetflow_maintenance_log"/>
        <field name="groups" eval="[(4, ref('group_assetflow_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

    <!-- ==== Audits -->
    <!-- An auditor is any user listed on the cycle — often a plain employee. -->
    <record id="rule_audit_cycle_auditor" model="ir.rule">
        <field name="name">Audit cycle: assigned auditors</field>
        <field name="model_id" ref="model_assetflow_audit_cycle"/>
        <field name="groups" eval="[(4, ref('group_assetflow_employee'))]"/>
        <field name="domain_force">[('auditor_ids', 'in', [user.id])]</field>
    </record>

    <record id="rule_audit_cycle_manager" model="ir.rule">
        <field name="name">Audit cycle: all</field>
        <field name="model_id" ref="model_assetflow_audit_cycle"/>
        <field name="groups" eval="[(4, ref('group_assetflow_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

    <record id="rule_audit_line_auditor" model="ir.rule">
        <field name="name">Audit line: assigned auditors</field>
        <field name="model_id" ref="model_assetflow_audit_line"/>
        <field name="groups" eval="[(4, ref('group_assetflow_employee'))]"/>
        <field name="domain_force">[('cycle_id.auditor_ids', 'in', [user.id])]</field>
    </record>

    <record id="rule_audit_line_manager" model="ir.rule">
        <field name="name">Audit line: all</field>
        <field name="model_id" ref="model_assetflow_audit_line"/>
        <field name="groups" eval="[(4, ref('group_assetflow_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

</odoo>
