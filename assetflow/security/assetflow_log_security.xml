<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================ -->
    <!--  Audit trail visibility                                           -->
    <!--                                                                   -->
    <!--  The old chatter inherited each record's own permissions: if you  -->
    <!--  could see the asset, you could read its history. A flat log      -->
    <!--  table has no such inheritance — res_model/res_id cannot be       -->
    <!--  resolved inside a domain — so visibility is granted explicitly.  -->
    <!--                                                                   -->
    <!--  Access rights already give every role read-only on the log, so   -->
    <!--  nobody can rewrite a trail. These rules decide who reads which   -->
    <!--  entries. Rules of the groups a user belongs to are OR-ed, so the -->
    <!--  manager's "everything" rule wins over the employee rule it       -->
    <!--  inherits.                                                        -->
    <!-- ================================================================ -->

    <!-- Employees see the asset lifecycle (which restates what the asset
         form already shows them) plus anything they did themselves. They do
         not get to read the trail of other people's allocations. -->
    <record id="rule_log_employee" model="ir.rule">
        <field name="name">Activity log: assets and own actions</field>
        <field name="model_id" ref="model_assetflow_log"/>
        <field name="groups" eval="[(4, ref('group_assetflow_employee'))]"/>
        <field name="domain_force">['|',
            ('res_model', '=', 'assetflow.asset'),
            ('author_id', '=', user.id)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Asset Managers and Administrators read the whole trail: that is what
         makes it an audit trail rather than a personal activity feed. -->
    <record id="rule_log_manager" model="ir.rule">
        <field name="name">Activity log: everything</field>
        <field name="model_id" ref="model_assetflow_log"/>
        <field name="groups" eval="[(4, ref('group_assetflow_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

</odoo>
