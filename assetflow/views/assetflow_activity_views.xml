<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ================================================================== -->
    <!--  SCREEN 10 — ACTIVITY LOGS & NOTIFICATIONS                         -->
    <!--                                                                    -->
    <!--  Every AssetFlow model logs its events to assetflow.log via the    -->
    <!--  _log() mixin. These views gather those lines into one feed:       -->
    <!--    * My Notifications — activity that concerns the current user    -->
    <!--    * Activity Log     — the full "who did what, when" audit trail  -->
    <!-- ================================================================== -->

    <record id="view_assetflow_log_tree" model="ir.ui.view">
        <field name="name">assetflow.log.tree</field>
        <field name="model">assetflow.log</field>
        <field name="arch" type="xml">
            <tree string="Activity" create="false" edit="false" delete="false"
                  decoration-warning="log_type == 'audit'"
                  decoration-muted="log_type == 'system'">
                <field name="create_date" string="When"/>
                <field name="body" string="Activity"/>
                <field name="res_name" string="Record"/>
                <field name="log_type" string="Type"/>
                <field name="author_id" string="By"/>
                <field name="user_id" string="Concerns" optional="show"/>
                <field name="res_model" optional="hide"/>
            </tree>
        </field>
    </record>

    <record id="view_assetflow_log_form" model="ir.ui.view">
        <field name="name">assetflow.log.form</field>
        <field name="model">assetflow.log</field>
        <field name="arch" type="xml">
            <form string="Activity" create="false" edit="false">
                <sheet>
                    <group>
                        <group>
                            <field name="author_id" string="By"/>
                            <field name="create_date" string="When"/>
                            <field name="log_type"/>
                        </group>
                        <group>
                            <field name="res_name" string="Record"/>
                            <field name="res_model" string="Record Type"/>
                            <field name="user_id" string="Concerns"/>
                        </group>
                    </group>
                    <field name="body" readonly="1"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_assetflow_log_search" model="ir.ui.view">
        <field name="name">assetflow.log.search</field>
        <field name="model">assetflow.log</field>
        <field name="arch" type="xml">
            <search string="Activity">
                <field name="body" string="Activity"/>
                <field name="res_name" string="Record"/>
                <field name="author_id" string="Author"/>
                <field name="user_id" string="Concerns"/>

                <!-- The mockup's filter tabs: All / Alerts / Approvals / Bookings -->
                <filter name="filter_alerts" string="Alerts"
                        domain="[('log_type', '=', 'audit')]"/>
                <filter name="filter_approvals" string="Approvals"
                        domain="[('log_type', 'in', ('allocation', 'maintenance'))]"/>
                <filter name="filter_bookings" string="Bookings"
                        domain="[('log_type', '=', 'booking')]"/>
                <separator/>
                <filter name="filter_mine" string="By Me"
                        domain="[('author_id', '=', uid)]"/>
                <filter name="filter_concerns_me" string="Concerns Me"
                        domain="[('user_id', '=', uid)]"/>
                <separator/>
                <filter name="filter_today" string="Today"
                        domain="[('create_date', '>=', datetime.datetime.combine(context_today(), datetime.time(0,0,0)))]"/>

                <group expand="0" string="Group By">
                    <filter name="group_type" string="Type"
                            context="{'group_by': 'log_type'}"/>
                    <filter name="group_model" string="Record Type"
                            context="{'group_by': 'res_model'}"/>
                    <filter name="group_author" string="Author"
                            context="{'group_by': 'author_id'}"/>
                    <filter name="group_date" string="Date"
                            context="{'group_by': 'create_date:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Activity addressed to the current user. -->
    <record id="action_assetflow_my_notifications" model="ir.actions.act_window">
        <field name="name">My Notifications</field>
        <field name="res_model">assetflow.log</field>
        <field name="view_mode">tree,form</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'tree', 'view_id': ref('view_assetflow_log_tree')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_assetflow_log_form')})]"/>
        <field name="search_view_id" ref="view_assetflow_log_search"/>
        <field name="domain">[('user_id', '=', uid)]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">You're all caught up</p>
            <p>Asset assignments, approvals, booking confirmations, overdue
               alerts and audit flags that concern you show up here.</p>
        </field>
    </record>

    <!-- The full audit trail: every logged AssetFlow event, managers only. -->
    <record id="action_assetflow_activity_log" model="ir.actions.act_window">
        <field name="name">Activity Log</field>
        <field name="res_model">assetflow.log</field>
        <field name="view_mode">tree,form</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'tree', 'view_id': ref('view_assetflow_log_tree')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_assetflow_log_form')})]"/>
        <field name="search_view_id" ref="view_assetflow_log_search"/>
        <field name="context">{'search_default_group_type': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No activity recorded yet</p>
            <p>A chronological record of who did what across AssetFlow —
               allocations, transfers, maintenance, bookings and audits.</p>
        </field>
    </record>

    <!-- ================================================================== -->
    <!--  ACTIVITY MENU                                                     -->
    <!-- ================================================================== -->
    <menuitem id="menu_assetflow_activity"
              name="Activity"
              parent="menu_assetflow_root"
              sequence="40"/>

    <menuitem id="menu_assetflow_my_notifications"
              name="My Notifications"
              parent="menu_assetflow_activity"
              action="action_assetflow_my_notifications"
              sequence="10"/>

    <menuitem id="menu_assetflow_activity_log"
              name="Activity Log"
              parent="menu_assetflow_activity"
              action="action_assetflow_activity_log"
              sequence="20"
              groups="assetflow.group_assetflow_manager"/>

</odoo>
