<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_assetflow_audit_cycle_tree" model="ir.ui.view">
        <field name="name">assetflow.audit.cycle.tree</field>
        <field name="model">assetflow.audit.cycle</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="department_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="status" decoration-success="status == 'closed'" decoration-warning="status == 'active'"/>
                <field name="total_assets"/>
                <field name="discrepancy_count" decoration-danger="discrepancy_count &gt; 0"/>
            </tree>
        </field>
    </record>

    <record id="view_assetflow_audit_cycle_form" model="ir.ui.view">
        <field name="name">assetflow.audit.cycle.form</field>
        <field name="model">assetflow.audit.cycle</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="status" widget="statusbar" statusbar_visible="active,closed"/>
                    <button name="action_close" string="Close Audit Cycle" type="object" class="btn-primary"
                        attrs="{'invisible': [('status', '!=', 'active')]}"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="%(action_assetflow_audit_check_assets)d" type="action" class="oe_stat_button"
                            icon="fa-check-circle" attrs="{'invisible': [('status', '!=', 'active')]}">
                            <div class="o_stat_info">
                                <field name="verified_count" widget="statinfo" string="Verified"/>
                            </div>
                        </button>
                        <button name="%(action_assetflow_audit_discrepancies)d" type="action" class="oe_stat_button"
                            icon="fa-exclamation-triangle" context="{'search_default_discrepancies': 1}">
                            <div class="o_stat_info text-danger">
                                <field name="discrepancy_count" widget="statinfo" string="Discrepancies"/>
                            </div>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="department_id"/>
                            <field name="location"/>
                        </group>
                        <group>
                            <field name="start_date"/>
                            <field name="end_date"/>
                            <field name="auditor_ids" widget="many2many_tags"/>
                        </group>
                    </group>
                    <field name="check_ids">
                        <tree editable="bottom">
                            <field name="asset_id"/>
                            <field name="check_status" widget="radio"/>
                            <field name="notes"/>
                            <field name="checked_by_id"/>
                            <field name="checked_at"/>
                        </tree>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_assetflow_audit_check_tree" model="ir.ui.view">
        <field name="name">assetflow.audit.check.tree</field>
        <field name="model">assetflow.audit.check</field>
        <field name="arch" type="xml">
            <tree>
                <field name="audit_id"/>
                <field name="asset_id"/>
                <field name="check_status" decoration-success="check_status == 'verified'"
                    decoration-danger="check_status in ('missing','damaged')"/>
                <field name="checked_by_id"/>
                <field name="checked_at"/>
            </tree>
        </field>
    </record>

    <record id="view_assetflow_audit_check_search" model="ir.ui.view">
        <field name="name">assetflow.audit.check.search</field>
        <field name="model">assetflow.audit.check</field>
        <field name="arch" type="xml">
            <search>
                <field name="audit_id"/>
                <field name="asset_id"/>
                <filter name="discrepancies" string="Discrepancies" domain="[('check_status','in',('missing','damaged'))]"/>
                <filter name="verified" string="Verified" domain="[('check_status','=','verified')]"/>
                <filter name="pending" string="Pending" domain="[('check_status','=','pending')]"/>
            </search>
        </field>
    </record>
</odoo>
