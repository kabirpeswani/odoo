<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_assetflow_category_tree" model="ir.ui.view">
        <field name="name">assetflow.category.tree</field>
        <field name="model">assetflow.category</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="description"/>
            </tree>
        </field>
    </record>

    <record id="view_assetflow_category_form" model="ir.ui.view">
        <field name="name">assetflow.category.form</field>
        <field name="model">assetflow.category</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="description"/>
                    </group>
                    <page name="assets" string="Assets">
                        <field name="asset_ids">
                            <tree>
                                <field name="asset_tag"/>
                                <field name="name"/>
                                <field name="status"/>
                                <field name="condition"/>
                            </tree>
                        </field>
                    </page>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
