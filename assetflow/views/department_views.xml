<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_assetflow_department_tree" model="ir.ui.view">
        <field name="name">assetflow.department.tree</field>
        <field name="model">assetflow.department</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="head_id"/>
                <field name="parent_department_id"/>
                <field name="status"/>
            </tree>
        </field>
    </record>

    <record id="view_assetflow_department_form" model="ir.ui.view">
        <field name="name">assetflow.department.form</field>
        <field name="model">assetflow.department</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="head_id"/>
                            <field name="parent_department_id"/>
                            <field name="status"/>
                        </group>
                    </group>
                    <notebook>
                        <page name="employees" string="Employees">
                            <field name="employee_ids">
                                <tree>
                                    <field name="name"/>
                                    <field name="email"/>
                                    <field name="role"/>
                                    <field name="status"/>
                                </tree>
                            </field>
                        </page>
                        <page name="assets" string="Assets">
                            <field name="asset_ids">
                                <tree>
                                    <field name="asset_tag"/>
                                    <field name="name"/>
                                    <field name="category_id"/>
                                    <field name="status"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_assetflow_department_search" model="ir.ui.view">
        <field name="name">assetflow.department.search</field>
        <field name="model">assetflow.department</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="head_id"/>
                <filter name="active" string="Active" domain="[('status','=','active')]"/>
                <filter name="inactive" string="Inactive" domain="[('status','=','inactive')]"/>
            </search>
        </field>
    </record>
</odoo>
